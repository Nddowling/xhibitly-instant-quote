      ]
    },
    {
      "entity_name": "NormalizedProductCategory",
      "allowed_operations": [
        "read"
      ]
    },
    {
      "function_name": "generateBrandedProductImage"
    }
  ],
  "whatsapp_greeting": "Hi \u2014 I\u2019m your internal Exhibitors' Handbook assistant. I can help you navigate the app, open the right internal pages, find products, and support booth, quote, executive, and setup workflows."
